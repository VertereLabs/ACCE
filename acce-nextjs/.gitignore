# Ignore EVERYTHING by default
# *

# Except the out folder (production build)
# !out/
# !out/**

# Keep the .gitignore itself
# !.gitignore

# Dependencies
node_modules/

# Next.js build output
.next/
out/

# Environment files
.env
.env.local
.env.*.local

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Test artifacts
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
coverage/