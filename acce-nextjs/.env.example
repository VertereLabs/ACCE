# ACCE Tutors — Phase 1a environment (PHASE-1A-PLAN.md §7).
# Copy to .env and fill in. Never commit real secrets.

# Postgres (Coolify). Use the public/external connection string for local
# migrate/seed/test; the internal string is used by the deployed container.
DATABASE_URL=

# Better Auth — generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://portal.accetutors.co.za
APP_URL=https://portal.accetutors.co.za

# Paystack (test-mode keys for dev). Only needed for Epic 4 (online payment).
PAYSTACK_SECRET_KEY=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

# Resend (email). Magic-link can log the URL to the console in dev, so this is
# not required to build/test login — only to send real email.
RESEND_API_KEY=
EMAIL_FROM=ACCE Tutors <no-reply@accetutors.co.za>
