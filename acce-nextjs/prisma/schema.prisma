// ACCE Tutors — Phase 1a (Group Classes MVP) data model.
// Domain models per PHASE-1A-PLAN.md §2; Better Auth tables (User/Session/
// Account/Verification) live in the same schema and are owned by Better Auth's
// magic-link + admin plugins. Regenerate/reconcile the auth tables with
// `npx @better-auth/cli generate` once src/lib/auth.ts is configured (Story 1.2).

generator client {
  provider = "prisma-client-js"
  // Driver adapters are GA in Prisma 6.16+; installed version is 6.19.3 — no
  // previewFeatures needed. If downgraded below 6.16, add:
  //   previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Better Auth (magic-link + admin plugin) — standard v1 shape.
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          String?   @default("STUDENT") // admin plugin: STUDENT | ADMIN
  banned        Boolean?  @default(false)
  banReason     String?
  banExpires    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]
  enrollments   Enrollment[]
  ledgerEntries LedgerEntry[] // NFR5: referential integrity for wallet ledger

  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String   @unique
  ipAddress      String?
  userAgent      String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy String? // admin plugin
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("session")
  @@index([userId])
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
  @@index([userId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
  @@index([identifier])
}

// ─────────────────────────────────────────────────────────────────────────────
// ACCE domain — group classes, enrollments, wallet ledger, payments.
// ─────────────────────────────────────────────────────────────────────────────

model Subject {
  // seeded: Accounting, Management Accounting & Finance, Auditing, Tax
  id       String         @id @default(cuid())
  name     String         @unique
  sessions GroupSession[]
}

enum Mode {
  ONLINE
  IN_PERSON
}

enum GroupSessionStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

model GroupSession {
  id          String             @id @default(cuid())
  subjectId   String
  subject     Subject            @relation(fields: [subjectId], references: [id])
  level       String // "CTA/PGDA" etc. (string tag in 1a; Level model arrives with 1b)
  title       String
  description String?
  start       DateTime
  end         DateTime
  capacity    Int // 4–6
  priceCents  Int // R290 = 29000
  mode        Mode               @default(ONLINE)
  location    String?
  meetingUrl  String? // MANUAL in 1a; auto-gen deferred behind MeetingProvider
  status      GroupSessionStatus @default(SCHEDULED)
  enrollments Enrollment[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @default(now()) @updatedAt // AD-16: optimistic-concurrency token for admin edits (@default(now()) matches the migration's DEFAULT CURRENT_TIMESTAMP — no schema/DB drift)
}

enum EnrollmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  ATTENDED
  NO_SHOW
}

model Enrollment {
  id               String           @id @default(cuid())
  studentId        String
  student          User             @relation(fields: [studentId], references: [id])
  groupSessionId   String
  session          GroupSession     @relation(fields: [groupSessionId], references: [id])
  priceCents       Int
  status           EnrollmentStatus @default(PENDING)
  pendingExpiresAt DateTime? // hold during Paystack round-trip
  paymentRef       String?          @unique // AD-7: pins webhook→enrollment join (idempotency)
  createdAt        DateTime         @default(now())

  // one seat per student per class
  // fast capacity count
  @@unique([studentId, groupSessionId])
  @@index([groupSessionId, status])
}

enum LedgerType {
  PACKAGE_PURCHASE
  TOPUP
  BOOKING_CHARGE
  CANCELLATION_REFUND
  CANCELLATION_FEE
  WITHDRAWAL
  ADJUSTMENT
}

model LedgerEntry {
  id                String     @id @default(cuid())
  studentId         String
  student           User       @relation(fields: [studentId], references: [id]) // NFR5: FK for referential integrity (RESTRICT on delete — rows must survive)
  type              LedgerType
  amountCents       Int // signed
  balanceAfterCents Int
  enrollmentId      String?
  paymentRef        String?
  createdAt         DateTime   @default(now())

  // Partial unique index enforcing one BOOKING_CHARGE per enrollment (AD-8) is
  // hand-added to migration SQL — Prisma does not emit partial-unique indexes.
  // See migration: CREATE UNIQUE INDEX "LedgerEntry_enrollmentId_booking_charge_key"
  //                ON "LedgerEntry"("enrollmentId") WHERE type = 'BOOKING_CHARGE';
  // NFR5: FK index
  // ledger history query (existing)
  @@index([studentId])
  @@index([studentId, createdAt])
}

model Payment {
  // Paystack mirror, written by webhook (idempotency)
  id          String   @id @default(cuid())
  reference   String   @unique
  amountCents Int
  status      String
  type        String
  raw         Json
  createdAt   DateTime @default(now())
}
